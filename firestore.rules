rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Lead validation
    function isValidLead(data) {
      return data.keys().hasAll(['name', 'email', 'createdAt', 'responded'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.email is string && data.email.size() > 0 && data.email.size() <= 200
        && data.createdAt is timestamp
        && data.responded is bool
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 50))
        && (!('serviceInterested' in data) || (data.serviceInterested is string && data.serviceInterested.size() <= 100))
        && (!('message' in data) || (data.message is string && data.message.size() <= 2000));
    }

    match /leads/{leadId} {
      // Anyone can submit a lead payload
      allow create: if isValidLead(incoming()) 
        && incoming().createdAt == request.time
        && incoming().responded == false;
      
      // Temporary: Allow reading leads for the dashboard. 
      // NOTE: For production, enable Anonymous Auth in Firebase Console and use: if isSignedIn();
      allow read: if true;
      
      // Restricted operations require authentication
      allow update, delete: if isSignedIn();
    }
  }
}
